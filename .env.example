# open-db-mcp configuration.
#
# Discovery is fully driven by environment variables. For each database family
# you want to expose, fill in one block below — the source name is the part
# between the family prefix and the key (e.g. PG_ANALYTICS_HOST defines a
# Postgres source named "ANALYTICS").
#
# Restart the container after changing this file. No code edit required.

# === Server ===
PORT=3000
LOG_LEVEL=info
TZ=UTC

# Comma-separated list of allowed Origin values for the /mcp endpoint.
# Empty (default) emits NO Access-Control-Allow-Origin header at all.
# Single "*" opens CORS to every origin. Otherwise the request's Origin is
# matched exactly against this allow-list.
# MCP_CORS_ORIGINS=https://app.example.com,https://staging.example.com

# When "true", the server also accepts ?api_key=<token> in the URL. Off by
# default — query strings leak into reverse-proxy logs and Referer headers.
# Prefer the Authorization or X-Api-Key header.
# MCP_ALLOW_QUERY_KEY=false


# === Users & roles ===
# Each user has a token and a role. Reads are unrestricted for any authenticated
# user; writes additionally require role >= writer AND the per-source WRITE
# flag (PG_<NAME>_WRITE=true, etc.) — both gates must agree.
#
# Roles:
#   reader (default) — can run db_execute_query and all listing tools
#   writer           — also allowed to call db_execute_write on writable sources
#   admin            — same write capability as writer; reserved for future
#                      admin-only endpoints. Does NOT bypass the source WRITE
#                      flag.
#
# Pattern: MCP_USER_<NAME>=<token>  with optional MCP_USER_<NAME>_ROLE
MCP_USER_ADMIN=changeme
MCP_USER_ADMIN_ROLE=admin
# MCP_USER_DEV=token-for-dev
# MCP_USER_DEV_ROLE=writer
# MCP_USER_ALI=token-for-ali        # default role is reader
#
# Legacy form (still supported, comma-separated token:role):
# MCP_API_KEYS=changeme:admin,sometoken:reader


# === PostgreSQL ===
# Pattern: PG_<NAME>_<KEY>
# PG_MAIN_HOST=host.docker.internal
# PG_MAIN_PORT=5432
# PG_MAIN_USER=postgres
# PG_MAIN_PASS=secret
# PG_MAIN_DB=main_db
# PG_MAIN_SSLMODE=prefer
# PG_MAIN_WRITE=false   # ⚠️ "true" unlocks db_execute_write on this source. Default off.


# === MySQL / MariaDB ===
# MYSQL_APP_HOST=host.docker.internal
# MYSQL_APP_PORT=3306
# MYSQL_APP_USER=root
# MYSQL_APP_PASS=secret
# MYSQL_APP_DB=app_db
# MYSQL_APP_TLS=        # "true" or "skip-verify" to enable TLS
# MYSQL_APP_WRITE=false # ⚠️ "true" unlocks db_execute_write on this source. Default off.


# === ClickHouse ===
# CH_OLAP_HOST=host.docker.internal
# CH_OLAP_PORT=9000     # native protocol
# CH_OLAP_USER=default
# CH_OLAP_PASS=
# CH_OLAP_DB=default
# CH_OLAP_SECURE=false
# CH_OLAP_WRITE=false   # ⚠️ "true" unlocks db_execute_write on this source. Default off.


# === MongoDB ===
# Either a full URI:
# MONGO_LOGS_URI=mongodb://user:pass@host:27017/dbname
# Or individual pieces:
# MONGO_LOGS_HOST=host.docker.internal
# MONGO_LOGS_PORT=27017
# MONGO_LOGS_USER=root
# MONGO_LOGS_PASS=secret
# MONGO_LOGS_DB=app
# MONGO_LOGS_AUTH_DB=admin


# === Redis ===
# Either a URL:
# REDIS_CACHE_URL=redis://:password@host:6379/0
# Or pieces:
# REDIS_CACHE_HOST=host.docker.internal
# REDIS_CACHE_PORT=6379
# REDIS_CACHE_PASS=
# REDIS_CACHE_DB=0


# === SQLite ===
# SQLITE_LOCAL_PATH=/data/app.db
# SQLITE_LOCAL_WRITE=false  # ⚠️ "true" removes the query_only PRAGMA so db_execute_write works. Default off.


# === Elasticsearch ===
# ES_LOGS_URL=https://elastic.example.com:9200
# ES_LOGS_API_KEY=BASE64_ID_AND_KEY        # preferred
# ES_LOGS_USER=elastic                     # alternative to API key
# ES_LOGS_PASS=secret
# ES_LOGS_INSECURE_TLS=false


# === CLOG Profile (Optional — enables clog_* tools) ===
# A "CLOG" profile turns one of your Elasticsearch sources into a log-search
# backend. Set CLOG_ES_SOURCE to the name of an ES_<NAME>_* source above.
#
# CLOG_ES_SOURCE=LOGS
# CLOG_INGRESS_INDEX=logs-ingress-*
# CLOG_LOGS_PREFIX=logs-
# CLOG_ALL_LOGS_INDEX=logs-*
#
# Optional: override field candidates if your log shipper uses different names.
# Each list is searched in order; the first present field wins.
# CLOG_NAMESPACE_FIELDS=kubernetes.namespace,k8s.namespace
# CLOG_CONTAINER_FIELDS=kubernetes.container_name,container.name
# CLOG_SERVICE_FIELDS=kubernetes.pod_labels.app,service.name
# CLOG_INGRESS_STATUS_FIELDS=status,http.status_code
# CLOG_INGRESS_LATENCY_FIELDS=request_time,latency,duration
# CLOG_INGRESS_HOST_FIELDS=host,http.host
# CLOG_INGRESS_PATH_FIELDS=path,uri,url.path
